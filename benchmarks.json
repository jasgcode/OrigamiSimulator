{
    "waterbomb-test": {
        "model": "/Bases/waterbombBase.svg",
        "colorMode": "faceTriangleID",
        "pointA": 5,
        "pointB": 42,
        "facePoints": { "0": 3, "5": 2 },
        "showPointNumbers": false,
        "steps": [
            { "fold": 0,   "pov": "iso" },
            { "fold": 50,  "pov": "z" },
            { "fold": 100, "pov": "-z" }
        ],
        "pauseDuration": 2,
        "autoCapture": false
    },
    "waterbomb-animate": {
        "model": "/Bases/waterbombBase.svg",
        "colorMode": "labelOnly",
        "color1": "ec008b",
        "color2": "dddddd",
        "backgroundColor": "f5f5f5",
        "pointA": 5,
        "pointB": 42,
        "facePoints": {
            "0": [{ "u": 0.33, "v": 0.33, "w": 0.34 }, { "u": 0.5, "v": 0.5, "w": 0 }],
            "5": [{ "u": 0.5, "v": 0.25, "w": 0.25 }]
        },
        "showPointNumbers": true,
        "fold": 10,
        "pauseDuration": 3,
        "previewRotation": {
            "duration": 5,
            "povKeyframes": [
                { "progress": 0, "pov": "iso" },
                { "progress": 25, "pov": "z" },
                { "progress": 50, "pov": "x" },
                { "progress": 75, "pov": "-y" },
                { "progress": 100, "pov": "iso" }
            ]
        },
        "foldAnimation": {
            "from": 0,
            "to": 90,
            "duration": 5,
            "delayAfterPreview": 1,
            "povKeyframes": [
                { "fold": 0, "pov": "iso" },
                { "fold": 33, "pov": "z" },
                { "fold": 66, "pov": "y" },
                { "fold": 90, "pov": "iso" }
            ],
            "hidePointsDuringAnimation": true
        }
    },
    "waterbomb-animate-fit": {
        "model": "/Bases/waterbombBase.svg",
        "colorMode": "faceTriangleID",
        "backgroundColor": "f5f5f5",
        "pointA": 5,
        "pointB": 42,
        "facePoints": { "0": 3, "5": 2 },
        "showPointNumbers": false,
        "foldAnimation": {
            "from": 0,
            "to": 90,
            "duration": 4,
            "trackModel": true,
            "povKeyframes": [
                { "fold": 0, "pov": "iso" },
                { "fold": 33, "pov": "z" },
                { "fold": 90, "pov": "iso" }
            ],
            "hidePointsDuringAnimation": true
        }
    },
    "crane-fold": {
        "model": "/Bases/birdBase.svg",
        "colorMode": "labelOnly",
        "color1": "ec008b",
        "color2": "dddddd",
        "pointA": 3,
        "pointB": 10,
        "showPointNumbers": false,
        "steps": [
            { "fold": 0,   "pov": "iso" },
            { "fold": 25,  "pov": "x" },
            { "fold": 50,  "pov": "y" },
            { "fold": 75,  "pov": "-x" },
            { "fold": 95, "pov": "iso" }
        ],
        "pauseDuration": 3,
        "autoCapture": true
    }
}
